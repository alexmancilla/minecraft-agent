# Copia este archivo como ".env" y rellena lo que uses.

# Backend de transcripcion: local | groq | openai
STT_BACKEND=groq

# Si usas Groq (recomendado: rapido y barato). Saca la key en https://console.groq.com/keys
GROQ_API_KEY=

# Si usas OpenAI. Saca la key en https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Opcionales:
# STT_MODEL=whisper-large-v3-turbo   # override del modelo cloud
# WHISPER_MODEL=base                 # modelo local (si STT_BACKEND=local)
# MIC_DEVICE=1                       # indice del microfono (ver --list)
